# Copy to .env and fill in. See tech-stack.md "Environment & Services" for
# the full list this grows to across later phases.

# Neon Postgres. DATABASE_URL is the pooled connection used at runtime;
# DIRECT_URL is the unpooled connection used by `prisma migrate`.
# For local dev without a Neon branch, point both at a local Postgres
# instance (see README).
DATABASE_URL="postgresql://user:password@host:5432/db?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/db?schema=public"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Better Auth. Required. Signs session cookies and verification/reset tokens.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Google OAuth. Optional — set both or neither. When unset, the Google
# sign-in button is not rendered and only email/password auth is available.
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend. Optional in development — when RESEND_API_KEY is unset, outbound
# emails are printed to the server console instead of being sent. Required in
# production. EMAIL_FROM must be set whenever RESEND_API_KEY is.
RESEND_API_KEY=""
EMAIL_FROM="Tedxplore <no-reply@tedxplore.com>"

# Cloudinary. Optional in development — when unset, uploads are refused with a
# clear message and every image slot renders its FR-38 fallback. Required in
# production. The cloud name is public (it appears in every delivery URL); the
# key and secret are credentials. Find all three under
# Programmable Media → Dashboard → Product Environment Credentials.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Vercel Cron. Optional locally. Shared secret the scheduled maintenance sweep
# (/api/cron/sweep) requires as `Authorization: Bearer <CRON_SECRET>`. When
# unset the route is fail-closed in production (refuses everyone) and open only
# in development. Generate with: openssl rand -base64 32
CRON_SECRET=""

# React Bits (https://reactbits.dev). Build-time only — used by the shadcn CLI
# to authenticate against the paid Starter/Pro registries (see components.json).
# Free components (@react-bits/*) need no key. Not read by the app at runtime.
REACTBITS_LICENSE_KEY=""
