# Copy to .env and fill in. See tech-stack.md "Environment & Services" for
# the full list this grows to across later phases.

# Neon Postgres. DATABASE_URL is the pooled connection used at runtime;
# DIRECT_URL is the unpooled connection used by `prisma migrate`.
# For local dev without a Neon branch, point both at a local Postgres
# instance (see README).
DATABASE_URL="postgresql://user:password@host:5432/db?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/db?schema=public"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Better Auth. Required. Signs session cookies and verification/reset tokens.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Google OAuth. Optional — set both or neither. When unset, the Google
# sign-in button is not rendered and only email/password auth is available.
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend. Optional in development — when RESEND_API_KEY is unset, outbound
# emails are printed to the server console instead of being sent. Required in
# production. EMAIL_FROM must be set whenever RESEND_API_KEY is.
RESEND_API_KEY=""
EMAIL_FROM="Tedxplore <no-reply@tedxplore.com>"
